          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dbo.dim_mouvement WHERE mouvement_key = -1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT dbo.dim_mouvement ON;&#xA;&#xA;    INSERT INTO dbo.dim_mouvement (&#xA;        mouvement_key,&#xA;        date_comptabilisation,&#xA;        reference_client,&#xA;        reference_commande,&#xA;        code_jalon,&#xA;        qte_entree,&#xA;        qte_sortie,&#xA;        qte_encours,&#xA;        sortie_vers_venue_de,&#xA;        type_mouvement&#xA;    )&#xA;    VALUES (&#xA;        -1,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL&#xA;    );&#xA;&#xA;    SET IDENTITY_INSERT dbo.dim_mouvement OFF;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
