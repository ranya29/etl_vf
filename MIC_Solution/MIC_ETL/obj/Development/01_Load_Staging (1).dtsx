              <properties>
                <property
                  dataType="System.Int32"
                  description="Nombre de secondes avant l'expiration d'une commande.  Une valeur égale à 0 indique un délai d'expiration infini."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Spécifie le nom de l'objet de base de données utilisé pour ouvrir un ensemble de lignes."
                  name="OpenRowset">[dbo].[Jalons]</property>
                <property
                  dataType="System.String"
                  description="Spécifie la variable contenant le nom de l'objet de base de données utilisé pour ouvrir un ensemble de lignes."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST([timestamp] AS datetime2) AS source_timestamp,
    CAST(document_type AS nvarchar(50)) AS document_type,
    CAST(document_no AS nvarchar(50)) AS document_no,
    CAST(bl_origine AS nvarchar(50)) AS bl_origine,
    CAST(date_comptabilisation AS datetime2) AS date_comptabilisation,
    CAST(date_creation AS datetime2) AS date_creation,
    NULLIF(LTRIM(RTRIM(reference_client)), '') AS reference_client,
    NULLIF(LTRIM(RTRIM(no_commande)), '') AS reference_commande,
    CAST(avancement AS int) AS avancement,
    CAST(qte_entree AS decimal(18,3)) AS qte_entree,
    CAST(qte_sortie AS decimal(18,3)) AS qte_sortie,
    CAST(qte_encours AS decimal(18,3)) AS qte_encours,
    CAST(sortie_vers_venue_de AS nvarchar(50)) AS sortie_vers_venue_de,
    CAST(mouvement_manuel AS bit) AS mouvement_manuel,
    CAST(utilisateur AS nvarchar(50)) AS utilisateur,
    GETDATE() AS stg_load_date
FROM source_transfert;</property>
                <property
                  dataType="System.String"
                  description="Variable contenant la commande SQL à exécuter."
                  name="SqlCommandVariable"></property>
                <property
