          SQLTask:Connection="{F67CA6A5-7B73-4480-8F92-FFBFB401C00D}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dbo.dim_jalon WHERE jalon_key = -1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT dbo.dim_jalon ON;&#xA;&#xA;    INSERT INTO dbo.dim_jalon (jalon_key, code_jalon, nom_jalon)&#xA;    VALUES (-1, NULL, NULL);&#xA;&#xA;    SET IDENTITY_INSERT dbo.dim_jalon OFF;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
