              <properties>
                <property
                  dataType="System.Int32"
                  description="Nombre de secondes avant l'expiration d'une commande.  Une valeur égale à 0 indique un délai d'expiration infini."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Spécifie le nom de l'objet de base de données utilisé pour ouvrir un ensemble de lignes."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Spécifie la variable contenant le nom de l'objet de base de données utilisé pour ouvrir un ensemble de lignes."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST([nom_jalon] AS NVARCHAR(50)) AS nom_jalon,
    CAST([ref] AS NVARCHAR(50)) AS reference_commande,
    CAST([client] AS NVARCHAR(50)) AS reference_client,
    CAST([po] AS NVARCHAR(50)) AS po,
    CAST([size] AS NVARCHAR(10)) AS taille,
    CAST([inseam] AS NVARCHAR(10)) AS inseam,
    CAST([codeb] AS NVARCHAR(50)) AS codeb,
    CAST([datelecture] AS DATETIME2(7)) AS date_lecture,
    CAST([disponibilité] AS INT) AS disponibilite,
    CAST([reprise] AS INT) AS reprise,
    CAST([auto] AS INT) AS auto_flag,
    CAST([version] AS NVARCHAR(10)) AS version_code,
    CAST([façonnier] AS NVARCHAR(50)) AS designation_faconnier,
    CAST([lavage] AS NVARCHAR(50)) AS lavage,
    CAST([modelll] AS NVARCHAR(50)) AS modele,
    CAST([utilisateur] AS NVARCHAR(50)) AS utilisateur,
    CAST([bonliv] AS NVARCHAR(50)) AS bon_livraison,
    CAST([qté] AS DECIMAL(18,3)) AS qte_defaut,
    CAST(CAST([Défaults] AS NVARCHAR(MAX)) AS NVARCHAR(MAX)) AS defaut,
    CAST(CAST([Catégorie_default] AS NVARCHAR(MAX)) AS NVARCHAR(MAX)) AS categorie_defaut,
    CAST(CAST([Atelier] AS NVARCHAR(MAX)) AS NVARCHAR(MAX)) AS atelier,
    CAST(CAST([type ligne vente] AS NVARCHAR(MAX)) AS NVARCHAR(MAX)) AS type_ligne_vente,
    CAST([saison] AS NVARCHAR(10)) AS saison,
    CAST([flag] AS INT) AS flag,
    GETDATE() AS stg_load_date
FROM dbo.A900_Deuxieme_choix;</property>
                <property
