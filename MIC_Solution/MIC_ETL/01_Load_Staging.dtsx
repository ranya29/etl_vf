                <property
                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST([Référence client] AS NVARCHAR(70)) AS reference_client,
    CAST([Document No_] AS NVARCHAR(50)) AS reference_commande,
    CAST([Location Code] AS NVARCHAR(50)) AS location_code,
    CAST([Quantity] AS INT) AS quantity,
    CAST([Lavage] AS NVARCHAR(170)) AS lavage,
    CAST([Modèle] AS NVARCHAR(170)) AS modele,
    CAST([Désignation Tissu] AS NVARCHAR(150)) AS designation_tissu,
    CAST([Désignation Façonnier] AS NVARCHAR(70)) AS designation_faconnier,
    CAST([Product Group Code] AS NVARCHAR(50)) AS product_group_code,
    CAST([PARAMPAGE] AS NVARCHAR(70)) AS parampage,
    CAST([Planned] AS INT) AS planned,
    CAST([Completely Shipped] AS INT) AS completely_shipped,
    CAST([Ligne Soldée] AS INT) AS ligne_soldee,
    CAST([Season] AS NVARCHAR(20)) AS saison,
    CAST([Schedulded Export Date] AS DATETIME) AS date_export_prevue,
    CAST([Quantity Shipped] AS DECIMAL(18,3)) AS quantity_shipped,
    CAST([Date Export] AS DATETIME) AS date_export,
    CAST([Code standard] AS NVARCHAR(10)) AS code_standard,
    CAST([Schedulded Export Week] AS INT) AS semaine_export_prevue,
    CAST([RefWIC] AS NVARCHAR(50)) AS ref_wic,
    CAST([Semaine Export] AS NVARCHAR(10)) AS semaine_export,
    CAST([Colisage_cloturé] AS INT) AS colisage_cloture,
    GETDATE() AS stg_load_date
FROM dbo.mes_info_de_base_wic;</property>
