                <property
                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    CAST([Document Type] AS INT) AS document_type,
    CAST([Document No_] AS NVARCHAR(50)) AS document_no,
    CAST([N° BL Origine] AS NVARCHAR(50)) AS bl_origine,
    CAST([Date Comptabilisation] AS DATETIME) AS date_comptabilisation,
    CAST([Date Création] AS DATETIME) AS date_creation,
    CAST(NULLIF(LTRIM(RTRIM([Réference Client])), '') AS NVARCHAR(50)) AS reference_client,
    CAST(NULLIF(LTRIM(RTRIM([No_ Commande])), '') AS NVARCHAR(50)) AS reference_commande,
    CAST([Avancement] AS INT) AS avancement,
    CAST([Qte entrée] AS DECIMAL(18,3)) AS qte_entree,
    CAST([Qte Sortie] AS DECIMAL(18,3)) AS qte_sortie,
    CAST([Qte Encours] AS DECIMAL(18,3)) AS qte_encours,
    CAST([Status] AS INT) AS status,
    CAST([N° BL Sortie] AS NVARCHAR(10)) AS bl_sortie,
    CAST([Sortie Vers_ Venue de] AS INT) AS sortie_vers_venue_de,
    CAST([Avancement OLD] AS INT) AS avancement_old,
    CAST([Sortie Vers_ Venue de OLD] AS INT) AS sortie_vers_venue_de_old,
    CAST([Avancement OLD 2] AS INT) AS avancement_old_2,
    CAST([Sortie Vers_ Venue de OLD 2] AS INT) AS sortie_vers_venue_de_old_2,
    CAST([Utilisateur] AS NVARCHAR(50)) AS utilisateur,
    GETDATE() AS stg_load_date
FROM dbo.[WIC$En-tête Transfert Atelier];</property>
