                          containsID="true"
                          dataType="System.String"
                          description="Expression de colonne dérivée"
                          name="Expression">[LEFT](#{Package\Load Dim_Saison\Source OLE DB.Outputs[Sortie de source OLE DB].Columns[Season]},1) == "A" ? "Autumn" : [LEFT](#{Package\Load Dim_Saison\Source OLE DB.Outputs[Sortie de source OLE DB].Columns[Season]},1) == "S" ? "Summer" : [LEFT](#{Package\Load Dim_Saison\Source OLE DB.Outputs[Sortie de source OLE DB].Columns[Season]},1) == "W" ? "Winter" : "U"</property>
