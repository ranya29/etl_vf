          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM Dim_Saison WHERE SaisonKey = -1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT Dim_Saison ON;&#xA;&#xA;    INSERT INTO Dim_Saison&#xA;    (SaisonKey&#xA;      ,CodeSaison&#xA;      ,Année&#xA;      ,TypeSaison&#xA;      ,DateInsertion&#xA;      ,DateModification)&#xA;    VALUES&#xA;    (-1,'UNKNOWN',NULL,'UNKNOWN',GETDATE(),GETDATE());&#xA;&#xA;    SET IDENTITY_INSERT Dim_Saison OFF;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
