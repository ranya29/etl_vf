          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dbo.dim_commande WHERE commande_key = -1)&#xA;BEGIN&#xA;    SET IDENTITY_INSERT dbo.dim_commande ON;&#xA;&#xA;    INSERT INTO dbo.dim_commande (&#xA;        commande_key,&#xA;        reference_commande,&#xA;        reference_client,&#xA;        qte_planifiee_source,&#xA;        lavage,&#xA;        modele,&#xA;        designation_tissu,&#xA;        designation_faconnier,&#xA;        nom_client_source,&#xA;        ligne_soldee,&#xA;        saison,&#xA;        date_export_prevue,&#xA;        date_export,&#xA;        code_standard,&#xA;        semaine_export_prevue,&#xA;        semaine_export&#xA;    )&#xA;    VALUES (&#xA;        -1,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL,&#xA;        NULL&#xA;    );&#xA;&#xA;    SET IDENTITY_INSERT dbo.dim_commande OFF;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
